{
  "name": "thomas-couderc-resume",
  "version": "1.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "dev:all": "next dev & storybook dev -p 6006",
    "dev:clean": "rm -rf .next .turbo 2>/dev/null; next dev",
    "dev:fresh": "rm -rf .next .turbo node_modules/.cache 2>/dev/null; next dev",
    "ngrok": "ngrok http 3000",
    "lint": "next lint",
    "lint-staged": "lint-staged",
    "prettier": "prettier --write --ignore-unknown .",
    "prettier:check": "prettier --check --ignore-unknown .",
    "start": "next start",
    "start:prod": "npm run build && next start",
    "test": "npm run prettier:check && npm run lint",
    "test:unit": "tsx --test lib/match-catalog-expand.unit.test.ts lib/tech-match-core.unit.test.ts lib/dev-domain-tags.unit.test.ts lib/ops-domain-tags.unit.test.ts lib/framework-display-order.unit.test.ts lib/contact-maps.unit.test.ts lib/offer-contact-from-params.unit.test.ts lib/cv-mode-nav.unit.test.ts lib/offer-to-match-url.unit.test.ts lib/slug.unit.test.ts lib/format-match-years.unit.test.ts lib/sort-chronological.unit.test.ts lib/capitalize-first.unit.test.ts lib/cv-print-routes.unit.test.ts lib/cv-path-utils.unit.test.ts lib/search-params-to-url.unit.test.ts lib/date.unit.test.ts lib/cv-contract-text.unit.test.ts lib/job-selection.unit.test.ts lib/profile-api.unit.test.ts",
    "playwright:install": "playwright install chromium",
    "test:playwright": "playwright install chromium && playwright test",
    "clean": "rm -rf node_modules",
    "reinstall": "npm run clean && npm install",
    "rebuild": "npm run clean && npm install && npm run build",
    "encode-offer-spec": "node scripts/encode-offer-spec.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "0.2.32",
    "@vercel/analytics": "0.1.11",
    "eslint": "10.2.0",
    "intl-dateformat": "0.1.4",
    "negotiator": "0.6.3",
    "next": "14.2.35",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/nextjs": "10.3.5",
    "@storybook/react": "10.3.5",
    "@types/negotiator": "0.6.1",
    "@types/node": "18.11.18",
    "@types/react": "18.0.26",
    "@types/react-dom": "^18.0.7",
    "ajv": "8.18.0",
    "autoprefixer": "^10.4.13",
    "encoding": "^0.1.13",
    "eslint-config-next": "14.2.35",
    "ngrok": "^4.3.3",
    "postcss": "^8.4.20",
    "prettier": "^2.8.1",
    "prettier-plugin-tailwindcss": "^0.2.1",
    "storybook": "10.3.5",
    "tailwindcss": "^3.2.7",
    "tsx": "^4.19.2",
    "typescript": "4.9.4"
  }
}
